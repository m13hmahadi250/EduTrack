rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isVerifiedEmail() {
      // Temporarily relaxing for dev environment, but keeping structure for hardening
      return isSignedIn();
    }

    // --- Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['id', 'role', 'name', 'email', 'balance', 'isVerified', 'isTrackingOn']) &&
               data.id == userId &&
               data.role in ['student', 'tutor', 'admin'] &&
               data.name is string && data.name.size() <= 128 &&
               data.email is string && data.email.size() <= 128 &&
               data.balance is number &&
               data.isVerified is bool &&
               data.isTrackingOn is bool &&
               (data.get('rating', null) == null || data.rating is number) &&
               (data.get('totalRatings', null) == null || data.totalRatings is number) &&
               (data.get('ratingSum', null) == null || data.ratingSum is number) &&
               (data.get('phone', null) == null || data.phone is string) &&
               (data.get('address', null) == null || data.address is string) &&
               (data.get('university', null) == null || data.university is string) &&
               (data.get('bio', null) == null || data.bio is string) &&
               (data.get('hourlyRate', null) == null || data.hourlyRate is number) &&
               (data.get('profileImage', null) == null || data.profileImage is string) &&
               (data.get('location', null) == null || (data.location is map && data.location.lat is number && data.location.lng is number));
      }

      allow read: if isSignedIn();

      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    (incoming().role != 'admin' || request.auth.token.email == 'admin@gmail.com');

      allow update: if (isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && 
                       incoming().role == existing().role && 
                       incoming().email == existing().email && 
                       incoming().balance == existing().balance && 
                       incoming().isVerified == existing().isVerified
                    ) || (
                       isSignedIn() && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'ratingSum', 'totalRatings'])
                    ) || isAdmin();

      allow delete: if isAdmin();
    }

    // --- Payments Collection ---
    match /payments/{paymentId} {
      function isValidPayment(data) {
        return data.keys().hasAll(['id', 'studentId', 'tutorId', 'amount', 'transactionId', 'status', 'date', 'bKashNumber']) &&
               data.amount is number && data.amount > 0 &&
               data.status in ['pending', 'approved', 'rejected'] &&
               isValidId(data.studentId) && isValidId(data.tutorId);
      }

      allow list: if isAdmin() || (isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.tutorId == request.auth.uid));
      allow get: if isAdmin() || (isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.tutorId == request.auth.uid));
      
      allow create: if isSignedIn() && isValidId(paymentId) && isValidPayment(incoming()) && 
                    incoming().studentId == request.auth.uid && 
                    incoming().status == 'pending';

      allow update: if (isAdmin() && isValidPayment(incoming())) || (
        isSignedIn() && resource.data.studentId == request.auth.uid && 
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status == 'cancelled'
      );
      
      allow delete: if isAdmin();
    }

    // --- Messages Collection ---
    match /messages/{messageId} {
      function isValidMessage(data) {
        return data.keys().hasAll(['id', 'senderId', 'receiverId', 'participants', 'content', 'timestamp', 'isRead']) &&
               data.content is string && data.content.size() <= 5000 &&
               data.senderId == (request.method == 'create' ? request.auth.uid : existing().senderId) &&
               data.participants.size() == 2 &&
               (request.auth.uid in data.participants);
      }

      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow get: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      allow create: if isSignedIn() && isValidId(messageId) && isValidMessage(incoming());
      
      allow update: if isSignedIn() && (
        (request.auth.uid == existing().receiverId && 
         incoming().diff(existing()).affectedKeys().hasOnly(['isRead']) &&
         incoming().isRead == true)
      );

      allow delete: if isAdmin();
    }

    // --- Sessions Collection ---
    match /sessions/{sessionId} {
      function isValidSession(data) {
        return data.keys().hasAll(['id', 'studentId', 'tutorId', 'subject', 'status', 'scheduledTime']) &&
               isValidId(data.studentId) && isValidId(data.tutorId) &&
               data.subject is string && data.subject.size() <= 200 &&
               data.status in ['scheduled', 'active', 'completed', 'cancelled'] &&
               data.scheduledTime is string;
      }

      allow list: if isAdmin() || (isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.tutorId == request.auth.uid));
      allow get: if isAdmin() || (isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.tutorId == request.auth.uid));

      allow create: if isSignedIn() && isValidId(sessionId) && isValidSession(incoming()) && 
                    incoming().studentId == request.auth.uid &&
                    incoming().status == 'scheduled';

      allow update: if isAdmin() || (
        isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.tutorId == request.auth.uid) && isValidSession(incoming())
      );

      allow delete: if isAdmin();
    }

    // --- Withdrawals Collection ---
    match /withdrawals/{withdrawalId} {
      function isValidWithdrawal(data) {
        return data.keys().hasAll(['id', 'tutorId', 'amount', 'bKashNumber', 'status', 'timestamp']) &&
               isValidId(data.tutorId) &&
               data.amount is number && data.amount > 0 &&
               data.bKashNumber is string && data.bKashNumber.size() <= 20 &&
               data.status in ['pending', 'approved', 'rejected'] &&
               data.timestamp is string;
      }

      allow list: if isAdmin() || (isSignedIn() && resource.data.tutorId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.tutorId == request.auth.uid);

      allow create: if isSignedIn() && isValidId(withdrawalId) && isValidWithdrawal(incoming()) && 
                    incoming().tutorId == request.auth.uid &&
                    incoming().status == 'pending';

      allow update: if isAdmin() && isValidWithdrawal(incoming());

      allow delete: if isAdmin();
    }

    // --- Notifications Collection ---
    match /notifications/{notificationId} {
      function isValidNotification(data) {
        return data.keys().hasAll(['id', 'userId', 'title', 'message', 'type', 'isRead', 'timestamp']) &&
               data.keys().size() == 7 &&
               isValidId(data.id) &&
               isValidId(data.userId) &&
               data.title is string && data.title.size() <= 200 &&
               data.message is string && data.message.size() <= 2000 &&
               data.type in ['info', 'success', 'warning', 'error'] &&
               data.isRead is bool &&
               data.timestamp is string;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming());
      
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && (
        incoming().diff(existing()).affectedKeys().hasOnly(['isRead'])
      );
      
      allow delete: if isAdmin();
    }

    // --- Typing Indicators ---
    match /typing/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && 
                   (incoming().get('typingTo', null) == null || isValidId(incoming().typingTo));
    }
  }
}
